    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this water-quality reading and produce a report.\n\nLocation: {{ $json.Location }}\nTimestamp: {{ $json.Timestamp }}\npH: {{ $json.pH }} (threshold: below 6)\nTurbidity: {{ $json.Turbidity }} NTU (threshold: above 50)\nDissolved Oxygen: {{ $json.DissolvedOxygen }} mg/L (threshold: below 5)",
        "options": {
          "systemMessage": "You are a Marine Environmental Scientist. Given a set of water-quality readings that have been flagged as polluted, respond with a concise, professional report containing exactly three clearly labeled sections:\n1. Pollution Assessment — a short summary of which parameters are out of safe range and the overall severity.\n2. Impact on Aquatic Life — the likely biological and ecological effects.\n3. Recommended Corrective Actions — practical, prioritized remediation steps.\nKeep the total response under 250 words and use plain, authoritative language."
        }
