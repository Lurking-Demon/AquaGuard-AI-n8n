    {
      "parameters": {
        "content": "## 2. Pollution Classification\nIF flags a reading as POLLUTED when pH < 6, Turbidity > 50 NTU, or Dissolved Oxygen < 5 mg/L."
      },
      "id": "1193db18-18ff-4402-9a45-e719ffed9f15",
